# Pionex API — create at pionex.com > API Management. Grant TRADE permission only,
# NO withdrawal permission. Restrict to your Mac Mini's egress IP if possible.
PIONEX_API_KEY=
PIONEX_API_SECRET=

# Dashboard auth token (pick something long and random)
DASHBOARD_TOKEN=changeme

# Trading — crypto majors + all Pionex index & financial products
# (xStocks equities, SPYX/QQQX index ETFs, gold/silver/oil)
SYMBOLS=BTC_USDT,ETH_USDT,SOL_USDT,SPYX_USDT,QQQX_USDT,AAPLX_USDT,AMZNX_USDT,GOOGLX_USDT,METAX_USDT,NVDAX_USDT,TSLAX_USDT,CRCLX_USDT,BMNRX_USDT,XAUT_USDT,PAXG_USDT,SLVX_USDT,USOX_USDT
INTERVAL=15m
MODE=paper            # paper | live  (start in paper!)
RISK_PER_TRADE=0.01
MAX_ALLOC_PER_POS=0.25
MAX_POSITIONS=10
DAILY_LOSS_HALT=0.03
ATR_STOP_MULT=2.0
ATR_TP_MULT=3.0
VOL_HALT_ATR_PCT=0.06
MIN_NOTIONAL=12
